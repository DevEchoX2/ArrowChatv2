{
  "app": "ArrowChatv2",
  "defaultChannel": "World-chat",
  "commands": [
    {
      "key": "help",
      "usage": "/help",
      "description": "List available commands.",
      "group": "utility"
    },
    {
      "key": "join",
      "usage": "/join World-chat",
      "description": "Join a public room.",
      "group": "rooms"
    },
    {
      "key": "rules",
      "usage": "/rules",
      "description": "Show server rules.",
      "group": "utility"
    },
    {
      "key": "dm",
      "usage": "/dm username",
      "description": "Open a direct message with a user.",
      "group": "messages"
    },
    {
      "key": "create",
      "usage": "/create room-name",
      "description": "Create a private room (max 15 members).",
      "group": "rooms"
    }
  ]
}
