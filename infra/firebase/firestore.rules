rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() { return request.auth != null; }
    function isOwner(userId) { return isAuthed() && request.auth.uid == userId; }
    function chatMemberDocPath(chatId, userId) {
      return /databases/$(database)/documents/chat_members/$(chatId + "_" + userId);
    }
    function isChatMember(chatId) {
      return isAuthed() && exists(chatMemberDocPath(chatId, request.auth.uid));
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /profiles/{userId} {
      allow read: if isAuthed();
      allow write: if isOwner(userId);
    }

    match /preferences/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /friendships/{docId} {
      allow read: if isAuthed() && (
        resource.data.userId == request.auth.uid ||
        resource.data.friendId == request.auth.uid
      );
      allow create: if isAuthed() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthed() && (
        resource.data.userId == request.auth.uid ||
        resource.data.friendId == request.auth.uid
      );
    }

    match /blocks/{docId} {
      allow read: if isAuthed() && (
        resource.data.blockerId == request.auth.uid ||
        resource.data.blockedId == request.auth.uid
      );
      allow create: if isAuthed() && request.auth.uid == request.resource.data.blockerId;
      allow update: if false;
      allow delete: if isAuthed() && resource.data.blockerId == request.auth.uid;
    }

    match /chats/{chatId} {
      allow read: if isChatMember(chatId);
      allow create: if isAuthed() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isAuthed() && resource.data.createdBy == request.auth.uid;
    }

    match /chat_members/{docId} {
      allow read: if isAuthed() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /messages/{messageId} {
      allow read: if isAuthed() && isChatMember(resource.data.chatId);
      allow create, update, delete: if false;
    }

    match /notifications/{docId} {
      allow read: if isAuthed() && resource.data.userId == request.auth.uid;
      allow create, update: if isAuthed() && request.auth.uid == request.resource.data.userId;
      allow delete: if isAuthed() && resource.data.userId == request.auth.uid;
    }

    match /attachments/{docId} {
      allow read: if isAuthed() && isChatMember(resource.data.chatId);
      allow write: if false;
    }
  }
}
